# ClearGate Admin UI — environment variable template
# Copy this file to .env.local for local dev; NEVER commit real secrets.
# In Coolify, set these as Runtime environment variables (secrets masked).
#
# See admin/coolify/DEPLOYMENT.md §2 for full documentation.

# ── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ── SvelteKit ─────────────────────────────────────────────────────────────────
# Required by @auth/sveltekit — must be 32+ random bytes.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
AUTH_SECRET=CHANGE_ME_generate_32_random_bytes

# ── GitHub OAuth (Web app) ────────────────────────────────────────────────────
# From your GitHub OAuth App registered for browser login.
CLEARGATE_GITHUB_WEB_CLIENT_ID=your_github_web_oauth_client_id
CLEARGATE_GITHUB_WEB_CLIENT_SECRET=your_github_web_oauth_client_secret  # SECRET

# ── MCP backend ───────────────────────────────────────────────────────────────
# Public URL of your deployed MCP instance.
PUBLIC_MCP_URL=https://mcp.cleargate.example.com

# ── Redis ─────────────────────────────────────────────────────────────────────
# Internal Coolify Redis URL (same Redis instance shared with MCP).
REDIS_URL=redis://redis-service-name:6379  # SECRET

# ── CORS / Origin ─────────────────────────────────────────────────────────────
# SvelteKit adapter-node uses ORIGIN for absolute URL construction.
# Must also be set on MCP service as CLEARGATE_ADMIN_ORIGIN to allow CORS.
CLEARGATE_ADMIN_ORIGIN=https://admin.cleargate.example.com

# ── Session ───────────────────────────────────────────────────────────────────
SESSION_COOKIE_NAME=cg_session

# ── Dev bypass (NEVER set in production) ─────────────────────────────────────
# CLEARGATE_DISABLE_AUTH=1
