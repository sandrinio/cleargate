# ClearGate Admin — environment variables
# Copy to .env.local for local development
# NEVER commit .env.local to version control

# URL of the ClearGate MCP server (required)
# e.g. https://cleargate-mcp.soula.ge or http://localhost:3001 in dev
CLEARGATE_MCP_URL=

# Origin this admin UI is served from — MCP reads this for CORS allow-list (required)
# Dev: http://localhost:5173
# Prod: https://admin.cleargate.soula.ge
CLEARGATE_ADMIN_ORIGIN=

# Redis connection URL for session storage (required)
# e.g. redis://localhost:6379 or rediss://user:pass@host:6380
REDIS_URL=

# GitHub OAuth App credentials — create at https://github.com/settings/developers
# For dev: create an "App for dev" pointing to http://localhost:5173/auth/callback/github
CLEARGATE_GITHUB_WEB_CLIENT_ID=
CLEARGATE_GITHUB_WEB_CLIENT_SECRET=

# Auth.js secret — generate with: openssl rand -base64 32
# Used to sign session cookies when not using the Redis adapter strategy
AUTH_SECRET=
