# OS
.DS_Store
Thumbs.db

# Editors / IDEs
.vscode/
.idea/
*.swp
*.swo

# Claude Code local config (root-only — runtime instance is not team-shared;
# canonical definitions live in cleargate-planning/.claude/ and ARE tracked)
/.claude/

# Private project notes (design guides, reference docs) — not shipped
/knowledge/

# Working notes / brainstorm drafts — local-only, not team-shared
/.cleargate/scratch/

# Active-sprint sentinel — per-machine runtime state, not team-shared
.cleargate/sprint-runs/.active

# Hook execution log — per-machine runtime, dirties git status on every session
/.cleargate/hook-log/

# Per-participant identity file — personal email, not team-shared
/.cleargate/.participant.json

# Sync drift marker — per-machine runtime state, not team-shared
# (anchored at any depth — also catches cleargate-cli/.cleargate/.sync-marker.json)
**/.cleargate/.sync-marker.json

# Comment snapshot cache — runtime-generated, not team-shared
/.cleargate/.comments-cache/

# Live-smoke harness output — PNG screenshots + JSON summaries per run,
# ephemeral debugging artefacts, not source.
/admin/scripts/smoke-output/

# Story worktrees — ephemeral per-story git worktrees (v2 execution)
.worktrees/

# Node — per-package .gitignore files handle node_modules/dist/.env
# but belt-and-suspenders at root:
node_modules/
