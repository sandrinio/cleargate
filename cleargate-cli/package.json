{
  "name": "cleargate",
  "version": "0.6.0",
  "private": false,
  "type": "module",
  "description": "Planning framework for Claude Code agents — sprint/epic/story protocol, four-agent loop (architect/developer/qa/reporter), Karpathy-style awareness wiki.",
  "license": "MIT",
  "bin": {
    "cleargate": "dist/cli.js"
  },
  "main": "./dist/cli.cjs",
  "module": "./dist/cli.js",
  "exports": {
    ".": {
      "types": "./dist/cli.d.ts",
      "import": "./dist/cli.js",
      "require": "./dist/cli.cjs"
    },
    "./admin-api": {
      "types": "./dist/admin-api/index.d.ts",
      "import": "./dist/admin-api/index.js",
      "require": "./dist/admin-api/index.cjs"
    }
  },
  "files": [
    "dist",
    "templates",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "prebuild": "tsx scripts/build-manifest.ts && node scripts/copy-planning-payload.mjs",
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "pretest": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@napi-rs/keyring": "^1.2.0",
    "commander": "^12",
    "diff": "^5.2.2",
    "js-yaml": "^4.1.0",
    "pg": "^8.12.0",
    "zod": "^4.3.0"
  },
  "devDependencies": {
    "@types/diff": "^5.2.3",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.0.0",
    "@types/pg": "^8.11.10",
    "tsup": "^8",
    "tsx": "^4.21.0",
    "typescript": "^5.8.0",
    "vitest": "^2.1.0"
  }
}
