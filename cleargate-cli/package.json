{
  "name": "@cleargate/cli",
  "version": "0.1.0-alpha.0",
  "private": false,
  "type": "module",
  "description": "ClearGate CLI — connects AI agent teams to the ClearGate MCP server",
  "bin": {
    "cleargate": "./dist/cli.js"
  },
  "main": "./dist/cli.cjs",
  "module": "./dist/cli.js",
  "exports": {
    ".": {
      "types": "./dist/cli.d.ts",
      "import": "./dist/cli.js",
      "require": "./dist/cli.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "pretest": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "commander": "^12",
    "zod": "^4.3.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsup": "^8",
    "typescript": "^5.8.0",
    "vitest": "^2.1.0"
  }
}
