{
  "name": "cleargate",
  "version": "0.1.0-alpha.1",
  "private": false,
  "type": "module",
  "description": "ClearGate CLI — connects AI agent teams to the ClearGate MCP server",
  "bin": {
    "cleargate": "dist/cli.js"
  },
  "main": "./dist/cli.cjs",
  "module": "./dist/cli.js",
  "exports": {
    ".": {
      "types": "./dist/cli.d.ts",
      "import": "./dist/cli.js",
      "require": "./dist/cli.cjs"
    },
    "./admin-api": {
      "types": "./dist/admin-api/index.d.ts",
      "import": "./dist/admin-api/index.js",
      "require": "./dist/admin-api/index.cjs"
    }
  },
  "files": [
    "dist",
    "templates",
    "README.md"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "pretest": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@napi-rs/keyring": "^1.2.0",
    "commander": "^12",
    "zod": "^4.3.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsup": "^8",
    "typescript": "^5.8.0",
    "vitest": "^2.1.0"
  }
}
